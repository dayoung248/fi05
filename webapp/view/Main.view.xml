<mvc:View
    controllerName="code.t4.ui5.fi05.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="[FI] 손익계산서">
        <content>
            <VBox class="sapUiSmallMargin">
                <OverflowToolbar>
                    <Label text="회사코드:"/>
                    <Input
                        id="bukrsInput"
                        value="{search>/Bukrs}"
                        maxLength="4"
                        placeholder="예: 1000"
                        width="10rem"/>
                    <ToolbarSeparator/>
                    <Label text="회계연도:"/>
                    <Input
                        id="gjahrInput"
                        value="{search>/Gjahr}"
                        maxLength="4"
                        type="Number"
                        liveChange=".onFiscalYearChange"
                        width="10rem"/>
                    <ToolbarSeparator/>
                    <Label text="회계주차:"/>
                    <Input
                        id="weeksInput"
                        value="{search>/Weeks}"
                        maxLength="2"
                        type="Number"
                        width="6rem"/>
                    <Button
                        text="조회"
                        type="Emphasized"
                        icon="sap-icon://search"
                        press=".onSearch"/>
                    <Button
                        text="초기화"
                        type="Default"
                        icon="sap-icon://refresh"
                        press=".onReset"/>
                    <ToolbarSpacer/>
                </OverflowToolbar>

                <VBox
                    alignItems="Center"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                    visible="{pl>/isSearched}">
                    <Title text="손익계산서" level="H2"/>
                    <Text text="{pl>/periods/current/periodText}"/>
                    <Text text="{pl>/periods/previous/periodText}"/>
                    <Text text="{pl>/periods/previous2/periodText}"/>
                </VBox>

                <HBox
                    width="100%"
                    justifyContent="End"
                    class="plUnitBar"
                    visible="{pl>/isSearched}">
                    <Text
                        text="{path: 'pl>/displayUnit', formatter: '.formatUnitText'}"
                        class="plUnitText"/>
                </HBox>

                <OverflowToolbar
                    class="sapUiTinyMarginBottom"
                    visible="{pl>/isSearched}">
                    <CheckBox
                        text="0원 계정 숨기기"
                        selected="{pl>/hideZeroRows}"
                        select=".onDisplayOptionsChange"/>
                    <ToolbarSeparator/>
                    <Label text="표시 단위"/>
                    <Select
                        selectedKey="{pl>/displayUnit}"
                        change=".onDisplayOptionsChange"
                        width="8rem">
                        <core:Item key="1" text="원 단위"/>
                        <core:Item key="1000" text="천원 단위"/>
                        <core:Item key="1000000" text="백만원 단위"/>
                    </Select>
                    <ToolbarSpacer/>
                    <Button
                        text="PDF 출력"
                        icon="sap-icon://pdf-attachment"
                        enabled="{pl>/isSearched}"
                        press=".onExportPdf"/>
                    <Button
                        text="Excel 다운로드"
                        icon="sap-icon://excel-attachment"
                        enabled="{pl>/isSearched}"
                        press=".onExportExcel"/>
                    <Button
                        text="차트 보기"
                        icon="sap-icon://bar-chart"
                        enabled="{pl>/isSearched}"
                        press=".onShowChart"/>
                </OverflowToolbar>

                <Table
                    id="plTable"
                    class="plTable sapUiTinyMarginTop"
                    items="{pl>/visibleItems}"
                    mode="None"
                    fixedLayout="true"
                    visible="{pl>/isSearched}">
                    <columns>
                        <Column width="40%">
                            <Text text="계정과목"/>
                        </Column>
                        <Column width="20%" hAlign="End">
                            <Text text="{pl>/periods/current/title}"/>
                        </Column>
                        <Column width="20%" hAlign="End">
                            <Text text="{pl>/periods/previous/title}"/>
                        </Column>
                        <Column width="20%" hAlign="End">
                            <Text text="{pl>/periods/previous2/title}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem vAlign="Middle">
                            <customData>
                                <core:CustomData key="rowType" value="{pl>rowType}" writeToDom="true"/>
                                <core:CustomData key="level" value="{pl>level}" writeToDom="true"/>
                                <core:CustomData key="statementLine" value="{pl>statementLine}" writeToDom="true"/>
                            </customData>
                            <cells>
                                <HBox alignItems="Center" class="plTableNameCell">
                                    <Button
                                        type="Transparent"
                                        class="plTableToggleButton"
                                        icon="{parts: [{path: 'pl>hasChildren'}, {path: 'pl>expanded'}], formatter: '.formatExpandIcon'}"
                                        enabled="{pl>hasChildren}"
                                        press=".onTogglePlRow"/>
                                    <Label
                                        text="{pl>name}"
                                        design="{path: 'pl>statementLine', formatter: '.formatStatementLabelDesign'}"
                                        class="plTableName"/>
                                </HBox>
                                <ObjectNumber
                                    textAlign="End"
                                    emphasized="{path: 'pl>statementLine', formatter: '.formatStatementEmphasized'}"
                                    number="{parts: [{path: 'pl>currentAmount'}, {path: 'pl>Waers'}, {path: 'pl>/displayUnit'}], formatter: '.formatCurrencyAmount'}"
                                    state="{parts: [{path: 'pl>currentAmount'}, {path: 'pl>rowType'}], formatter: '.formatCurrencyState'}"/>
                                <ObjectNumber
                                    textAlign="End"
                                    emphasized="{path: 'pl>statementLine', formatter: '.formatStatementEmphasized'}"
                                    number="{parts: [{path: 'pl>previousAmount'}, {path: 'pl>Waers'}, {path: 'pl>/displayUnit'}], formatter: '.formatCurrencyAmount'}"
                                    state="{parts: [{path: 'pl>previousAmount'}, {path: 'pl>rowType'}], formatter: '.formatCurrencyState'}"/>
                                <ObjectNumber
                                    textAlign="End"
                                    emphasized="{path: 'pl>statementLine', formatter: '.formatStatementEmphasized'}"
                                    number="{parts: [{path: 'pl>previous2Amount'}, {path: 'pl>Waers'}, {path: 'pl>/displayUnit'}], formatter: '.formatCurrencyAmount'}"
                                    state="{parts: [{path: 'pl>previous2Amount'}, {path: 'pl>rowType'}], formatter: '.formatCurrencyState'}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
